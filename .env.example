# Copy to .env and fill in secrets. Never commit .env.

# LLM — openai | anthropic | groq | ollama | openrouter | gemini (alias: google)
# Default: Gemini — set GOOGLE_API_KEY from https://aistudio.google.com/app/apikey
# OpenRouter + Gemma: LLM_PROVIDER=openrouter and OPENROUTER_API_KEY from https://openrouter.ai/keys
# If Anthropic says credit balance too low, use gemini/openrouter/groq or add Anthropic credits.
LLM_PROVIDER=gemini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-2-9b-it
OPENROUTER_HTTP_REFERER=https://github.com/cogniflow
OPENROUTER_APP_TITLE=CogniFlow
# Google Gemini (when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
# Used when provider is groq/ollama if you prefer a single override:
LLM_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# LangGraph checkpoints (thread_id = session_id): memory | sqlite
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=./data/checkpoints.db

# Embeddings & vector DB
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=cogniflow_docs

# Session / memory (SQLite)
SQLITE_DB_PATH=./data/memory.db

# Chunking & dialogue
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CONVERSATION_LENGTH=50
SUMMARY_THRESHOLD=10
SUMMARY_MAX_BULLETS=6
MEMORY_WINDOW_SIZE=5
# Drop weak Chroma matches; if none remain, skip main LLM for a fast "not in your docs" reply
RETRIEVAL_MIN_RELEVANCE=0.18

# Response cache (per session + user); cleared when new docs are indexed for that session
CHAT_EXACT_MESSAGE_CACHE_ENABLED=true
CHAT_EXACT_MESSAGE_CACHE_MAX_ENTRIES=512
CHAT_MESSAGE_CACHE_NORMALIZE_WHITESPACE=true
# exact | semantic | both (exact match first, then embedding similarity)
CHAT_RESPONSE_CACHE_MODE=both
# Lower = more paraphrase hits (risk of wrong answer); typical 0.78–0.90
CHAT_RESPONSE_CACHE_MIN_SIMILARITY=0.82
# sqlite (survives API restart — ChatGPT-like) | memory (single-process dev only)
CHAT_RESPONSE_CACHE_BACKEND=sqlite
CHAT_RESPONSE_CACHE_SQLITE_PATH=./data/response_cache.db
# Thread-aware keys: repeat hits drop after long chats but answers track conversation state
CHAT_RESPONSE_CACHE_INCLUDE_CONTEXT=false
CHAT_RESPONSE_CACHE_CONTEXT_MESSAGES=16

# FastAPI
EXPOSE_INTERNAL_ERRORS=false
API_HOST=0.0.0.0
API_PORT=8000
